{
  "name": "quartz-infinite-popovers-plugin",
  "version": "1.0.0",
  "description": "Infinite nested hover preview popovers with pinning, resizing, and drag support for Quartz",
  "author": "BernardSzr",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git@github.com:BernardSzr/Quartz-infinite-popovers-plugin.git"
  },
  "keywords": ["quartz", "quartz-plugin", "popover", "preview", "hover", "pin", "resize", "drag"],
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@quartz-community/types": "github:quartz-community/types",
    "@floating-ui/dom": "^1.7.4"
  },
  "peerDependencies": {
    "preact": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": false
    }
  },
  "devDependencies": {
    "sass": "^1.97.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10.9.2"
  },
  "quartz": {
    "name": "infinite-popover",
    "displayName": "Infinite Popover",
    "description": "Infinite nested hover preview popovers with pinning, resizing, and drag support",
    "category": "component",
    "version": "1.0.0",
    "quartzVersion": ">=5.0.0",
    "dependencies": [],
    "defaultOrder": 50,
    "defaultEnabled": true,
    "defaultOptions": {},
    "components": {
      "InfinitePopover": {
        "displayName": "Infinite Popover",
        "description": "Infinite nested hover preview popovers",
        "defaultPosition": "afterBody",
        "defaultPriority": 0
      }
    }
  }
}
